{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Catalog",
  "type": "object",
  "required": ["category", "products"],
  "properties": {
    "category": { "type": "string" },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "price"],
        "properties": {
          "id":    { "type": "integer" },
          "name":  { "type": "string" },
          "price": { "type": "number" }
        }
      }
    }
  }
}
