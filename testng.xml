<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  parallel="classes": each test class runs on its own thread. This is safe because
  the WebDriver is held per-thread in DriverFactory (ThreadLocal) and each class
  gets its own instance. (Method-level parallelism is intentionally NOT used: the
  driver/header are per-instance fields, so two methods of one class must not share
  a thread.)
-->
<suite name="DemoWebShop E2E Suite" verbose="1" parallel="classes" thread-count="2">

    <listeners>
        <listener class-name="com.demoshop.listeners.ScreenshotListener"/>
        <listener class-name="com.demoshop.listeners.RetryListener"/>
    </listeners>

    <test name="Registration and Digital Downloads">
        <classes>
            <class name="com.demoshop.tests.RegistrationAndDigitalDownloadsTest"/>
            <class name="com.demoshop.tests.RegistrationNegativeTest"/>
        </classes>
    </test>
</suite>
